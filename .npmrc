# save-exact: pin every installed package to its exact version (no ^ or ~ ranges),
#             producing a fully reproducible install from package.json alone.
save-exact=true

# engine-strict: fail `npm install` / `npm ci` if the active Node.js version does
#                not satisfy the `engines` field in package.json (>=24.0.0).
engine-strict=true

# fund: suppress the post-install funding message to keep CI output clean.
fund=false

# audit: run `npm audit` automatically after every install to surface known
#        vulnerabilities in the dependency tree.
audit=true
