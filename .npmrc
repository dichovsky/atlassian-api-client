; Required because `openapi-typescript@7.x` declares `peerDependencies.typescript: ^5.x`
; while this project targets TypeScript 6.x. Codegen output verified to compile under TS 6
; and the package only runs as a build-time tool, so the peer mismatch is benign.
; See: scripts/audit/codegen-confluence.mjs and spec/README.md.
legacy-peer-deps=true
