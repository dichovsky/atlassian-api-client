{
  "name": "atlassian-api-client",
  "version": "0.7.0",
  "description": "Typed Node.js/TypeScript clients and CLI for Atlassian Confluence Cloud REST API v2 and Jira Cloud Platform REST API v3",
  "keywords": [
    "atlassian",
    "confluence",
    "jira",
    "api",
    "client",
    "sdk",
    "cli",
    "typescript",
    "rest",
    "claude-code",
    "agent",
    "skill"
  ],
  "homepage": "https://github.com/dichovsky/atlassian-api-client#readme",
  "bugs": {
    "url": "https://github.com/dichovsky/atlassian-api-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dichovsky/atlassian-api-client.git"
  },
  "license": "MIT",
  "author": "Igor Magdich <magdich.igor@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "atlas": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "skill",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run validate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
    "typecheck": "tsc --noEmit",
    "test:exports": "node scripts/validate-exports.js",
    "audit:refresh": "node scripts/audit/refresh-spec.mjs",
    "audit:spec": "node scripts/audit/render-matrix.mjs",
    "codegen:confluence": "node scripts/audit/codegen-confluence.mjs",
    "validate": "npm run clean && npm run typecheck && npm run lint && npm run test:coverage && npm run format:check && npm run build && npm run test:exports && npm run audit:spec -- --check && npm run codegen:confluence -- --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
